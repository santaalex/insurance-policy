# ============================================================
# 保单管理系统 - 环境变量配置
# 复制此文件为 .env 并填写以下配置
# ============================================================

# ----- 数据库 -----
DB_PASSWORD=difypassword_change_me

# ----- Redis -----
REDIS_PASSWORD=difyredis_change_me

# ----- Dify 密钥 -----
# 必须是32位以上随机字符串，可用: openssl rand -base64 32
DIFY_SECRET_KEY=please-change-this-to-a-random-32-char-string

# ----- LLM 配置 (二选一) -----

# 选项A: 阿里云通义千问（推荐）
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-xxxxxxxx   # 阿里云 DashScope API Key
# LLM_MODEL=qwen-plus

# 选项B: OpenAI
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxxxxxx
# LLM_MODEL=gpt-4o-mini

OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your-aliyun-dashscope-api-key-here
LLM_MODEL=qwen-plus

# ----- Dify App API Key -----
# 在 Dify UI 完成初始化后，在"API访问"里获取，粘贴到这里
DIFY_APP_API_KEY=

# ----- Dify 知识库 ID -----
# 在 Dify UI 创建知识库后，URL里的UUID就是这个
DIFY_DATASET_ID=

# ----- 阿里云短信（已有）-----
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx
